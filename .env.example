NODE_ENV=staging
HTTP_PORT=8090
HASHING_SECRET=changeThisSecret

# Carpeta raíz que se escanea RECURSIVAMENTE en busca de imágenes.
# Usa una ruta absoluta. Las imágenes se muestran en orden natural (1, 2, 3... 10, 11...).
IMAGES_DIR=/ruta/absoluta/a/tu/carpeta/de/imagenes

# Cada cuántos ms se re-escanea la carpeta de imágenes para detectar cambios.
POLL_INTERVAL_MS=4000

# Carpeta PLANA (sin subcarpetas) donde se buscan videos.
# Los videos se muestran del más nuevo al más antiguo (por fecha de modificación).
VIDEOS_DIR=/ruta/absoluta/a/tu/carpeta/de/videos

# Cada cuántos ms se re-escanea la carpeta de videos.
VIDEO_POLL_INTERVAL_MS=6000
