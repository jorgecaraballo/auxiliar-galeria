NODE_ENV=staging
HTTP_PORT=8090
HASHING_SECRET=changeThisSecret

# Carpeta raíz que se escanea recursivamente (incluye subcarpetas) en busca
# de imágenes. Usa una ruta absoluta. Si la dejas vacía, se usa
# ./imagenes-ejemplo dentro del propio proyecto.
IMAGES_DIR=/ruta/absoluta/a/tu/carpeta/de/imagenes

# Cada cuántos milisegundos se vuelve a escanear la carpeta para detectar
# imágenes o subcarpetas nuevas automáticamente.
POLL_INTERVAL_MS=4000
